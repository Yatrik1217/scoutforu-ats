# Supabase — from your project's API settings (https://app.supabase.com → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Service role key — server-only. Used by scripts/seed.mjs and admin provisioning.
# NEVER expose this to the browser / commit it.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Password set on all seeded demo accounts (optional; defaults to scoutforu123)
SEED_PASSWORD=scoutforu123
