{
  "manifest_version": 3,
  "name": "ScoutforU — Resdex Import",
  "version": "1.0.0",
  "description": "Import a Naukri Resdex candidate into ScoutforU ATS with one click.",
  "permissions": ["storage", "downloads"],
  "host_permissions": [
    "https://scoutforu-ats.vercel.app/*",
    "<all_urls>"
  ],
  "action": { "default_popup": "popup.html", "default_title": "ScoutforU Import" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["https://*.naukri.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
